    "/api/matches": {
      "post": {
        "description": "Score and rank opportunities for the given profile.\n\nThe full bucket counts are always returned so the client knows\nthe total picture. Only the slice [offset, offset+limit) of visible\n(non-low_fit) results is returned in ``results``.\n\nSet ``semantic=true`` to blend LLM/TF-IDF semantic similarity into\nthe top 50 results (30% weight). Adds ~200-800ms latency when\nOpenAI key is configured; free when falling back to TF-IDF.",
        "operationId": "get_matches_api_matches_post",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 500,
              "maximum": 500,
